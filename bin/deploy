#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="${KOLLYWOOD_SERVER_DIR:-$HOME/projects/kollywood-server}"
RELEASE_DIR="$REPO_DIR/_build/prod/rel/kollywood"
SERVICE_NAME="kollywood-server.service"
DRAIN_TIMEOUT_SECONDS="${KOLLYWOOD_DRAIN_TIMEOUT_SECONDS:-900}"
ENV_FILE="${KOLLYWOOD_ENV_FILE:-$HOME/.config/kollywood-server/kollywood-server.env}"
POSTGRES_SERVICE_NAME="${KOLLYWOOD_POSTGRES_SERVICE_NAME:-kollywood-postgres.service}"

DEPLOY_SUCCESS=0
DRAIN_ENABLED=0

log() { printf '\033[1;34m==> %s\033[0m\n' "$*"; }
err() { printf '\033[1;31m==> ERROR: %s\033[0m\n' "$*" >&2; exit 1; }
require_env() {
  local name="$1"
  [[ -n "${!name:-}" ]] || err "Required environment variable $name is missing (source: $ENV_FILE)"
}

[[ -d "$REPO_DIR" ]] || err "Server repo not found at $REPO_DIR"

[[ -f "$ENV_FILE" ]] || err "Env file not found at $ENV_FILE"

cd "$REPO_DIR"

set -a
source "$ENV_FILE"
set +a

require_env DATABASE_URL
require_env SECRET_KEY_BASE
require_env PHX_HOST

if systemctl --user cat "$POSTGRES_SERVICE_NAME" >/dev/null 2>&1; then
  log "Starting $POSTGRES_SERVICE_NAME"
  systemctl --user start "$POSTGRES_SERVICE_NAME"
fi

on_exit() {
  exit_code=$?

  if [[ "$DEPLOY_SUCCESS" -eq 0 && "$DRAIN_ENABLED" -eq 1 ]]; then
    printf '\033[1;33m==> WARNING: deploy failed while maintenance drain is enabled.\033[0m\n' >&2
    printf '\033[1;33m==> Run `MIX_ENV=prod mix kollywood.orch.maintenance --mode normal` after recovery.\033[0m\n' >&2
  fi

  exit "$exit_code"
}

trap on_exit EXIT

log "Enabling maintenance drain"
MIX_ENV=prod mix kollywood.orch.maintenance --mode drain --wait --timeout "$DRAIN_TIMEOUT_SECONDS"
DRAIN_ENABLED=1

log "Pulling latest code"
git pull origin main --ff-only

SKILLS_SOURCE_DIR="$REPO_DIR/.agents/skills"
SKILLS_TARGET_DIR="$HOME/.agents/skills"

if [[ -d "$SKILLS_SOURCE_DIR" ]]; then
  log "Syncing repo skills to $SKILLS_TARGET_DIR"
  mkdir -p "$SKILLS_TARGET_DIR"

  for skill_path in "$SKILLS_SOURCE_DIR"/*; do
    [[ -d "$skill_path" ]] || continue
    skill_name="$(basename "$skill_path")"
    target_path="$SKILLS_TARGET_DIR/$skill_name"

    rm -rf "$target_path"
    cp -R "$skill_path" "$target_path"
  done
else
  log "No repo skills found at $SKILLS_SOURCE_DIR (skipping skill sync)"
fi

CLI_MANIFEST_PATH="$REPO_DIR/tools/kollywood-cli/Cargo.toml"
CLI_INSTALL_ROOT="${KOLLYWOOD_CLI_INSTALL_ROOT:-$HOME/.local}"
CLI_BIN_PATH="$CLI_INSTALL_ROOT/bin/kollywood"

[[ -f "$CLI_MANIFEST_PATH" ]] || err "Kollywood CLI manifest not found at $CLI_MANIFEST_PATH"

if ! command -v cargo >/dev/null 2>&1; then
  err "cargo is required to install the Kollywood CLI (missing from PATH)"
fi

log "Installing kollywood CLI to $CLI_INSTALL_ROOT/bin"
CLI_GIT_SHA=$(git rev-parse --short=8 HEAD)
KOLLYWOOD_CLI_GIT_SHA="$CLI_GIT_SHA" \
  cargo install --path "$REPO_DIR/tools/kollywood-cli" --locked --force --root "$CLI_INSTALL_ROOT"

[[ -x "$CLI_BIN_PATH" ]] || err "Kollywood CLI install failed: $CLI_BIN_PATH not found"

CLI_VERSION=$($CLI_BIN_PATH --version 2>/dev/null || true)
[[ -n "$CLI_VERSION" ]] || err "Installed Kollywood CLI did not start correctly"

if [[ "$CLI_VERSION" != *"+$CLI_GIT_SHA"* ]]; then
  err "Installed Kollywood CLI version mismatch (expected +$CLI_GIT_SHA, got: $CLI_VERSION)"
fi

log "Kollywood CLI installed: $CLI_VERSION"

log "Installing deps"
MIX_ENV=prod mix deps.get --only prod

log "Cleaning previous build artifacts"
MIX_ENV=prod mix clean

log "Compiling"
MIX_ENV=prod mix compile

log "Building assets"
MIX_ENV=prod mix assets.deploy

log "Building release"
MIX_ENV=prod mix release --overwrite

VERSION=$("$RELEASE_DIR/bin/kollywood" eval 'IO.puts(Kollywood.Version.full())' 2>/dev/null)
log "Release built: $VERSION"

log "Restarting $SERVICE_NAME"
systemctl --user restart "$SERVICE_NAME"

sleep 2

if systemctl --user is-active --quiet "$SERVICE_NAME"; then
  log "Service is running"
  systemctl --user status "$SERVICE_NAME" --no-pager | head -10
else
  err "Service failed to start"
fi

HEALTHCHECK_URL="${KOLLYWOOD_HEALTHCHECK_URL:-http://127.0.0.1:${PORT:-4000}/api/health}"
log "Checking health endpoint at $HEALTHCHECK_URL"

HEALTH_PAYLOAD=""
for _attempt in {1..15}; do
  if HEALTH_PAYLOAD=$(curl --silent --show-error --fail --max-time 3 "$HEALTHCHECK_URL"); then
    break
  fi

  sleep 1
done

[[ -n "$HEALTH_PAYLOAD" ]] || err "Health endpoint did not respond at $HEALTHCHECK_URL"

if [[ "$HEALTH_PAYLOAD" =~ \"status\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
  HEALTH_STATUS="${BASH_REMATCH[1]}"
else
  err "Health payload missing status: $HEALTH_PAYLOAD"
fi

if [[ "$HEALTH_PAYLOAD" =~ \"version_full\"[[:space:]]*:[[:space:]]*\"([^\"]+)\" ]]; then
  REPORTED_VERSION="${BASH_REMATCH[1]}"
else
  err "Health payload missing version_full: $HEALTH_PAYLOAD"
fi

[[ "$HEALTH_STATUS" == "ok" ]] || err "Health status is '$HEALTH_STATUS'"
[[ "$REPORTED_VERSION" == "$VERSION" ]] ||
  err "Health version mismatch (expected $VERSION, got $REPORTED_VERSION)"

log "Health check passed: $REPORTED_VERSION"

log "Restoring maintenance mode"
MIX_ENV=prod mix kollywood.orch.maintenance --mode normal
DRAIN_ENABLED=0

DEPLOY_SUCCESS=1

log "Deploy complete: $VERSION"
