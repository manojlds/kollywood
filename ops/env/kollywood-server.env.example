# Required
PHX_SERVER=true
PHX_HOST=localhost
PORT=4000
KOLLYWOOD_HOME=$HOME/.kollywood
DATABASE_URL=ecto://REPLACE_ME_USER:REPLACE_ME_PASSWORD@127.0.0.1:5432/kollywood_prod
SECRET_KEY_BASE=REPLACE_ME_SECRET_KEY_BASE

# Recommended for distributed control-plane semantics
KOLLYWOOD_CONTROL_STATE_BACKEND=db
KOLLYWOOD_ORCHESTRATOR_LEADER_ELECTION=true
KOLLYWOOD_INTERNAL_API_TOKEN=REPLACE_ME_INTERNAL_API_TOKEN

# Optional
POOL_SIZE=10
# KOLLYWOOD_TAILSCALE_SERVE_HTTPS_PORT=443
# ECTO_SSL=false
# ECTO_IPV6=false
